rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      // Allow if admin, otherwise check role. Need get() to read from users collection.
      // Careful with get() in rules, it costs a read.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'ADMIN';
    }

    // 1. Users Collection
    match /users/{userId} {
      // Anyone authenticated can read user profiles (needed for dropdowns, names)
      allow read: if isAuthenticated();
      // Users can write to their own profile, Admins can write to any profile
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // 2. Hubs Collection
    match /hubs/{hubId} {
      // Anyone authenticated can read the list of hubs (needed for map and dropdowns)
      allow read: if isAuthenticated();
      // Only Admins can create or modify hubs
      allow write: if isAdmin();
    }

    // 3. Batches Collection
    match /batches/{batchId} {
      // Anyone authenticated can read batches (needed for Loadboard pooling and Farmer tracking)
      allow read: if isAuthenticated();
      // Hub Managers can create/update batches. Admins can update.
      // (We allow broader write for MVP, ideally we restrict to originHubId == their hub)
      allow write: if isAuthenticated() && (getUserRole() == 'HUB_MANAGER' || isAdmin());
    }

    // 4. Trips Collection
    match /trips/{tripId} {
      // Anyone authenticated can read trips
      allow read: if isAuthenticated();
      // Admins can create/edit. Transporters can accept (update). Hub Managers can receive (update).
      allow write: if isAuthenticated() && (isAdmin() || getUserRole() == 'TRANSPORTER' || getUserRole() == 'HUB_MANAGER');
    }

    // 5. Live Locations
    match /live_locations/{locationId} {
      // Admins and Transporters can read
      allow read: if isAuthenticated();
      // Only the specific transporter can write their own location
      allow write: if isAuthenticated() && request.auth.uid == locationId;
    }
  }
}
