rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId || hasRole('ADMIN');
    }

    // --- Hubs ---
    match /hubs/{hubId} {
      allow read: if isSignedIn();
      allow write: if hasRole('ADMIN');
    }

    // --- Produce Batches ---
    match /batches/{batchId} {
      allow read: if isSignedIn() && (
        hasRole('ADMIN') || 
        getUserData().hubId == resource.data.originHubId ||
        getUserData().phoneNumber == resource.data.farmerPhone ||
        resource.data.status == 'IN_TRANSIT'
      );
      
      allow create: if hasRole('HUB_MANAGER') || hasRole('ADMIN');
      
      allow update: if hasRole('ADMIN') || (
        hasRole('HUB_MANAGER') && getUserData().hubId == resource.data.originHubId
      );
    }

    // --- Trips / Loads ---
    match /trips/{tripId} {
      allow read: if isSignedIn();
      
      allow create: if hasRole('ADMIN');
      
      allow update: if hasRole('ADMIN') || (
        hasRole('TRANSPORTER') && (
          resource.data.status == 'PENDING_BID' || 
          resource.data.vehicleId == request.auth.uid
        )
      ) || (
        hasRole('HUB_MANAGER') && getUserData().hubId == resource.data.destinationHubId
      );
    }

    // --- Notifications ---
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); // Allow app to trigger notifications
    }
  }
}
